{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/css/(.*)",    "dest": "/css/$1" },
    { "src": "/js/(.*)",     "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/photos/(.*)", "dest": "/photos/$1" },
    { "src": "/resume/(.*)", "dest": "/resume/$1" },
    { "src": "/contact",     "dest": "/api/contact.php" },
    { "src": "/(.*)",        "dest": "/api/index.php" }
  ]
}
